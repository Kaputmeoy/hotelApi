generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model House {
  id          Int            @id @default(autoincrement())
  number      Int            @unique
  deviceToken String         @unique @map("device_token")
  allSessions GuestSession[] @relation("HouseAllSessions")
  tasks       Task[]

  @@map("houses")
}

model GuestSession {
  id           String        @id @default(uuid())
  isActive     Boolean       @default(true) @map("is_active")
  checkInDate  DateTime      @default(now()) @map("check_in_date")
  checkOutDate DateTime?     @map("check_out_date")
  houseId      Int           @map("house_id")
  messages     ChatMessage[]
  house        House         @relation("HouseAllSessions", fields: [houseId], references: [id])
  tasks        Task[]

  @@index([houseId, isActive])
  @@map("guest_sessions")
}

model Role {
  id          Int    @id @default(autoincrement())
  name        String @unique
  permissions Json
  users       User[]

  @@map("roles")
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique
  passwordHash String        @map("password_hash")
  refreshToken String?       @map("refresh_token")
  roleId       Int           @map("role_id")
  messages     ChatMessage[]
  role         Role          @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Service {
  id           Int     @id @default(autoincrement())
  name         String
  description  String?
  isActive     Boolean @default(true) @map("is_active")
  requiresTime Boolean @default(false) @map("requires_time")
  priceInfo    Json?   @map("price_info")
  schema       Json?   @map("json_schema")
  tasks        Task[]

  @@map("services")
}

model Task {
  id             String          @id @default(uuid())
  status         TaskStatus      @default(NEW)
  requestedTime  DateTime?       @map("requested_time")
  details        Json?
  priceFix       Int             @map("price_fix")
  createdAt      DateTime        @default(now()) @map("created_at")
  houseId        Int             @map("house_id")
  sessionId      String          @map("session_id")
  serviceId      Int             @map("service_id")
  foodOrderItems FoodOrderItem[]
  house          House           @relation(fields: [houseId], references: [id])
  service        Service         @relation(fields: [serviceId], references: [id])
  session        GuestSession    @relation(fields: [sessionId], references: [id])

  @@index([houseId])
  @@index([sessionId])
  @@index([serviceId])
  @@map("tasks")
}

model FoodOrderItem {
  id           String   @id @default(uuid())
  quantity     Int
  priceAtOrder Int      @map("price_at_order")
  taskId       String   @map("task_id")
  menuItemId   String   @map("menu_item_id")
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("food_order_items")
}

model MealType {
  id        Int        @id @default(autoincrement())
  name      String
  startTime DateTime   @map("start_time") @db.Time(6)
  endTime   DateTime   @map("end_time") @db.Time(6)
  isActive  Boolean    @default(true) @map("is_active")
  menuItems MenuItem[] @relation("MealTypeToMenuItem")

  @@map("meal_types")
}

model MenuItem {
  id          String          @id @default(uuid())
  name        String
  description String?
  imageUrl    String?         @map("image_url")
  price       Int
  isAvailable Boolean         @default(true) @map("is_available")
  orderItems  FoodOrderItem[]
  mealTypes   MealType[]      @relation("MealTypeToMenuItem")

  @@map("menu_items")
}

model ChatMessage {
  id         String       @id @default(uuid())
  senderType SenderType   @map("sender_type")
  text       String
  isRead     Boolean      @default(false) @map("is_read")
  createdAt  DateTime     @default(now()) @map("created_at")
  sessionId  String       @map("session_id")
  staffId    String?      @map("staff_id")
  session    GuestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staff      User?        @relation(fields: [staffId], references: [id])

  @@index([sessionId])
  @@map("chat_messages")
}

model Setting {
  key      String  @id
  value    String
  imageUrl String? @map("image_url")

  @@map("settings")
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SenderType {
  GUEST
  STAFF
}
